{
  "name": "git-branch-panel",
  "displayName": "Git Branch Panel",
  "description": "A minimal VS Code extension that shows local and remote branches together.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:gitBranchPanel.branchesView",
    "onCommand:gitBranchPanel.refresh",
    "onCommand:gitBranchPanel.checkoutLocalBranch",
    "onCommand:gitBranchPanel.checkoutRemoteBranchAsLocal",
    "onCommand:gitBranchPanel.changeSortOrder",
    "onCommand:gitBranchPanel.openGithubRepository",
    "onCommand:gitBranchPanel.syncRemoteBranches"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitBranchPanel",
          "title": "Branches",
          "icon": "media/branches.svg"
        }
      ]
    },
    "views": {
      "gitBranchPanel": [
        {
          "id": "gitBranchPanel.branchesView",
          "name": "Local + Remote"
        }
      ]
    },
    "commands": [
      {
        "command": "gitBranchPanel.refresh",
        "title": "Git Branch Panel: Refresh"
      },
      {
        "command": "gitBranchPanel.checkoutLocalBranch",
        "title": "Checkout"
      },
      {
        "command": "gitBranchPanel.checkoutRemoteBranchAsLocal",
        "title": "Checkout as Local Branch"
      },
      {
        "command": "gitBranchPanel.changeSortOrder",
        "title": "Sort Branches",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "gitBranchPanel.openGithubRepository",
        "title": "Open GitHub Repository",
        "icon": "$(link-external)"
      },
      {
        "command": "gitBranchPanel.syncRemoteBranches",
        "title": "Sync Remote Branches",
        "icon": "$(sync)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitBranchPanel.refresh",
          "when": "view == gitBranchPanel.branchesView",
          "group": "navigation"
        },
        {
          "command": "gitBranchPanel.changeSortOrder",
          "when": "view == gitBranchPanel.branchesView",
          "group": "navigation@2"
        },
        {
          "command": "gitBranchPanel.openGithubRepository",
          "when": "view == gitBranchPanel.branchesView",
          "group": "navigation@99"
        }
      ],
      "view/item/context": [
        {
          "command": "gitBranchPanel.checkoutLocalBranch",
          "when": "view == gitBranchPanel.branchesView && (viewItem == localBranch || viewItem == currentLocalBranch)",
          "group": "navigation"
        },
        {
          "command": "gitBranchPanel.checkoutRemoteBranchAsLocal",
          "when": "view == gitBranchPanel.branchesView && viewItem == remoteBranch",
          "group": "navigation"
        },
        {
          "command": "gitBranchPanel.syncRemoteBranches",
          "when": "view == gitBranchPanel.branchesView && viewItem == remoteGroup",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.5"
  }
}
